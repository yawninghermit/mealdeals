# Supabase project URL and anon key (get from Supabase dashboard > Project Settings > API)
VITE_SUPABASE_URL=your_supabase_project_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Cloudflare Turnstile site key (get this from the Cloudflare dashboard)
# Must match the secret key configured in your Supabase project Auth settings
VITE_TURNSTILE_SITE_KEY=your_turnstile_site_key_here
